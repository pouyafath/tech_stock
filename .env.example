# Copy this file to .env and fill in your keys
# cp .env.example .env

# ── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: enrichment APIs (all have free tiers) ─────────────────────────
# Each enables additional signal sources. Missing keys cause that source to
# be silently skipped rather than failing the run.

# Finnhub — earnings calendar, analyst ratings, news sentiment
# Sign up: https://finnhub.io/register   (free: 60 calls/min)
FINNHUB_API_KEY=

# Alpha Vantage — backup price data, technical indicators
# Sign up: https://www.alphavantage.co/support/#api-key   (free: 5/min, 500/day)
ALPHA_VANTAGE_API_KEY=

# Twelve Data — global markets, ETF support, redundancy
# Sign up: https://twelvedata.com/account/register   (free: 800/day)
TWELVE_DATA_API_KEY=

# Polygon.io — options unusual activity, institutional signals
# Sign up: https://polygon.io/dashboard/signup   (free: 5/min)
POLYGON_API_KEY=

# FRED (Federal Reserve) — macro indicators (rates, inflation, VIX)
# Sign up: https://fred.stlouisfed.org/docs/api/api_key.html   (unlimited)
FRED_API_KEY=

# CoinGecko — crypto context (BTC correlation with risk-on/off)
# Sign up: https://www.coingecko.com/en/api/pricing   (free: 10K-30K calls/mo)
COINGECKO_API_KEY=

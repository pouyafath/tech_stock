# Copy this file to .env and fill in your keys
# cp .env.example .env

# ── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: enrichment APIs ────────────────────────────────────────────────
# Each enables additional signal sources. Missing keys do not fail the run;
# coverage gaps and source degradation are surfaced where applicable.

# Finnhub — earnings calendar, analyst ratings, news sentiment
# Sign up: https://finnhub.io/register
FINNHUB_API_KEY=

# Alpha Vantage — optional news and earnings enrichment
# Sign up: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Twelve Data — quote redundancy and some non-US symbol support
# Sign up: https://twelvedata.com/account/register
TWELVE_DATA_API_KEY=

# Polygon.io — snapshot and previous-session market data where plan permits
# Sign up: https://polygon.io/dashboard/signup
POLYGON_API_KEY=

# FRED (Federal Reserve) — macro indicators (rates, inflation, VIX, FX)
# Sign up: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# CoinGecko — crypto context (BTC correlation with risk-on/off)
# Sign up: https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=
